# ============================================================
# PR Review Bot — Environment Variables
# Copy this to .env and fill in your values
# Never commit .env to version control
# ============================================================

# GitHub webhook secret — set this same value in your GitHub webhook config
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# GitHub Personal Access Token — needs repo scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# OpenAI API Key
# Create at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Optional overrides
PORT=3000
OPENAI_MODEL=gpt-4o
BOT_AGENT_MODE=false
